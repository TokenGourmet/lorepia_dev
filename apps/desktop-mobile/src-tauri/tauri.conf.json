{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LorePia",
  "version": "0.1.0",
  "identifier": "dev.lorepia.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1423",
    "beforeBuildCommand": "node scripts/prepare-tauri-build.mjs",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LorePia",
        "width": 360,
        "height": 780
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "base-uri": "'none'",
        "connect-src": "'self'",
        "font-src": "'self'",
        "form-action": "'none'",
        "frame-src": "'none'",
        "img-src": "'none'",
        "media-src": "'none'",
        "object-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self'",
        "worker-src": "'none'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1423",
        "base-uri": "'none'",
        "connect-src": "'self' http://localhost:1423 ws://localhost:1424",
        "font-src": "'self' http://localhost:1423",
        "form-action": "'none'",
        "frame-src": "'none'",
        "img-src": "'none'",
        "media-src": "'none'",
        "object-src": "'none'",
        "script-src": "'self' http://localhost:1423",
        "style-src": "'self' http://localhost:1423",
        "worker-src": "'none'"
      },
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
