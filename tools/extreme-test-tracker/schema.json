{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lorepia.dev/schemas/extreme-test-tracker-v1.json",
  "title": "LorePia extreme test and launch audit tracker",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "asOf", "sources", "extremeChecks", "launchAudit"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "project": { "const": "LorePia" },
    "asOf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "commit", "branch"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "commit": { "$ref": "#/$defs/fullCommit" },
        "branch": { "type": "string", "minLength": 1 }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extremePlan", "launchAudit"],
      "properties": {
        "extremePlan": { "$ref": "#/$defs/source" },
        "launchAudit": { "$ref": "#/$defs/source" }
      }
    },
    "extremeChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultTracking", "ranges", "overrides"],
      "properties": {
        "defaultTracking": { "$ref": "#/$defs/checkTracking" },
        "ranges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checkRange" }
        },
        "overrides": {
          "type": "object",
          "propertyNames": { "pattern": "^[A-Z]+-[0-9]{3}$" },
          "additionalProperties": { "$ref": "#/$defs/checkTracking" }
        }
      }
    },
    "launchAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findings", "goConditions"],
      "properties": {
        "findings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/finding" }
        },
        "goConditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/goCondition" }
        }
      }
    }
  },
  "$defs": {
    "fullCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "nullableCommit": {
      "oneOf": [
        { "$ref": "#/$defs/fullCommit" },
        { "type": "null" }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value", "note"],
      "properties": {
        "kind": { "enum": ["commit", "path", "command", "artifact", "git", "manifest", "device", "measurement"] },
        "value": { "type": "string", "minLength": 1 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "checkTracking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence", "commit", "commands"],
      "properties": {
        "status": { "enum": ["not_run", "in_progress", "pass", "fail", "blocked", "unsupported"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "commit": { "$ref": "#/$defs/nullableCommit" },
        "commands": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "checkRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefix", "start", "end"],
      "properties": {
        "prefix": { "type": "string", "pattern": "^[A-Z]+$" },
        "start": { "type": "integer", "minimum": 1, "maximum": 999 },
        "end": { "type": "integer", "minimum": 1, "maximum": 999 }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "title", "status", "evidence", "commit", "commands", "remaining"],
      "properties": {
        "id": { "type": "string", "pattern": "^P[01]-[0-9]+$" },
        "severity": { "enum": ["P0", "P1"] },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "in_progress", "fixed", "verified", "accepted"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "commit": { "$ref": "#/$defs/nullableCommit" },
        "commands": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "remaining": { "type": "string", "minLength": 1 }
      }
    },
    "goCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "evidence", "commit", "commands"],
      "properties": {
        "id": { "type": "string", "pattern": "^GO-[0-9]{3}$" },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["not_run", "in_progress", "pass", "fail", "blocked", "unsupported"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "commit": { "$ref": "#/$defs/nullableCommit" },
        "commands": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
