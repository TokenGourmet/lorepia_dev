{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Exact app-command capability for the trusted main WebView",
  "webviews": ["main"],
  "permissions": [
    "allow-start-mock-stream",
    "allow-ack-stream",
    "allow-cancel-stream",
    "allow-get-stream-snapshot",
    "allow-register-host-broker-session",
    "allow-rotate-host-broker-session",
    "allow-host-broker-request",
    "allow-host-broker-probe-count",
    "allow-release-stream",
    "allow-wait-stream-terminal"
  ]
}
