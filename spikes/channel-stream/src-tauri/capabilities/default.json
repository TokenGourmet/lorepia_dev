{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "allow-start-mock-stream",
    "allow-ack-stream",
    "allow-cancel-stream",
    "allow-get-stream-snapshot",
    "allow-register-host-broker-session",
    "allow-rotate-host-broker-session",
    "allow-host-broker-request",
    "allow-host-broker-probe-count"
  ]
}
